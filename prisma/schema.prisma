generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String    @id
  name      String
  location  String    @default("")
  join_code String    @unique
  users     User[]
  shifts    Shift[]
  work_logs WorkLog[]
  branches  Branch[]
}

model Branch {
  id          String           @id @default(cuid())
  name        String
  address     String           @default("")
  business_id String
  created_at  DateTime         @default(now())
  business    Business         @relation(fields: [business_id], references: [id])
  employees   EmployeeBranch[]
  shifts      Shift[]

  @@index([business_id])
}

model EmployeeBranch {
  id          String   @id @default(cuid())
  user_id     String
  branch_id   String
  role        String   @default("employee")
  permissions String[] @default([])
  user        User     @relation(fields: [user_id], references: [id])
  branch      Branch   @relation(fields: [branch_id], references: [id])

  @@unique([user_id, branch_id])
  @@index([branch_id])
}

model User {
  id          String           @id
  name        String
  email       String           @unique
  role        String
  color       String
  phone       String?
  business_id String
  business    Business         @relation(fields: [business_id], references: [id])
  work_logs   WorkLog[]
  branches    EmployeeBranch[]
}

model Shift {
  id                   String             @id
  business_id          String
  branch_id            String?
  date                 String
  start_time           String
  end_time             String
  role_needed          String
  assigned_employee_id String?
  status               String
  notes                String?
  recurring_group_id   String?
  actual_start         String?
  actual_end           String?
  business             Business           @relation(fields: [business_id], references: [id])
  branch               Branch?            @relation(fields: [branch_id], references: [id])
  applications         ShiftApplication[]

  @@index([business_id])
  @@index([branch_id])
}

model ShiftApplication {
  id          String   @id @default(cuid())
  shift_id    String
  employee_id String
  status      String   @default("pending")
  created_at  DateTime @default(now())
  shift       Shift    @relation(fields: [shift_id], references: [id])

  @@index([shift_id])
  @@index([employee_id])
}

model WorkLog {
  id            String   @id
  employee_id   String
  employee_name String
  business_id   String
  date          String
  clock_in      String
  clock_out     String
  hours         Float
  notes         String?
  employee      User     @relation(fields: [employee_id], references: [id])
  business      Business @relation(fields: [business_id], references: [id])
}
